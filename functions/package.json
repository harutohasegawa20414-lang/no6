{
  "name": "no6-functions",
  "version": "1.0.0",
  "description": "No.6 - 工事日程調整自動化システム",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
