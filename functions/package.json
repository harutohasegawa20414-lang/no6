    "@google/generative-ai": "^0.21.0",
    "@types/express": "^5.0.6",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.0",
    "express": "^5.2.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "openai": "^6.32.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
